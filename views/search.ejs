<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevPrint — Search</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>

<!-- NAV -->
<nav class="nav">
    <a href="/" class="nav-logo">DEV<span>PRINT</span></a>
    <span class="nav-tagline">the developer's mirror</span>
    <div class="nav-actions">
        <a href="/card" class="btn-sm">← my card</a>
        <a href="/logout" class="btn-sm">logout</a>
    </div>
</nav>

<!-- ISSUE STRIP -->
<div class="issue-strip" style="margin-top: 56px;">
    <span>DEVPRINT · SEARCH / DISCOVER</span>
    <span>GITHUB INTELLIGENCE · 2025</span>
</div>

<div class="page-wrap" style="padding-top: 0;">
    <div class="search-body">

        <div class="search-left">
            <div class="search-prompt">$ devprint --search</div>
            <div class="search-rule"></div>
            <h1 class="search-h1">Find a</h1>
            <span class="search-h1-accent">Developer.</span>
            <p class="search-sub">Enter a GitHub username to pull live stats, repos, and language data.</p>

            <form action="/card" method="GET">
                <div class="input-field">
                    <span class="input-slash">/</span>
                    <input name="username" placeholder="github username…" autocomplete="off" autofocus />
                </div>
                <div class="input-hint">press enter or click generate</div>
                <div class="search-buttons">
                    <button type="submit" class="btn btn-primary">Generate card →</button>
                    <a href="/card" class="btn btn-ghost">← my card</a>
                </div>
            </form>

            <% if (error) { %>
                <div class="error-box">⚠ <%= error %></div>
            <% } %>
        </div>

        <div class="search-right">
            <div class="panel-head">What you'll get —</div>
            <div class="panel-rule"></div>
            <div class="panel-item">GitHub OAuth login <span class="panel-arrow">→</span></div>
            <div class="panel-item">Live GitHub API stats <span class="panel-arrow">→</span></div>
            <div class="panel-item">Top language breakdown <span class="panel-arrow">→</span></div>
            <div class="panel-item">Followers · following · repos <span class="panel-arrow">→</span></div>
            <div class="panel-item">Shareable card URL <span class="panel-arrow">→</span></div>
            <div class="panel-stack">→ node · express · ejs · github api</div>
        </div>

    </div>

    <div class="status-bar">
        <span><span class="status-dot"></span>READY</span>
        <span>DEVPRINT · NODE 20 · EXPRESS 4</span>
    </div>
</div>

</body>
</html>
