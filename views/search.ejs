<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DEVPRINT — Search</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wordmark">devprint</div>
  <h1>Search</h1>
  <h2>Enter a GitHub username to generate a card.</h2>
  <div class="card">
    <form action="/card" method="GET">
      <div class="input-wrap">
        <input
          name="username"
          type="text"
          placeholder="github username"
          autocomplete="off"
          autofocus
        />
        <button type="submit" class="btn">Generate →</button>
      </div>
    </form>
    <% if (error) { %>
      <div class="error-msg">⚠ <%= error %></div>
    <% } %>
  </div>
</body>
</html>
