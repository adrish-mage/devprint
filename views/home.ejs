<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevPrint — Your GitHub, Decoded</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>

<!-- NAV -->
<nav class="nav">
    <a href="/" class="nav-logo">DEV<span>PRINT</span></a>
    <span class="nav-tagline">the developer's mirror</span>
    <div class="nav-actions">
        <a href="/login" class="btn btn-accent">Login with Google</a>
    </div>
</nav>

<div class="home-wrap">

    <!-- HERO — centered exactly like reference screenshot -->
    <section class="hero">
        <div class="hero-eyebrow">// github intelligence tool</div>
        <h1 class="hero-h1">Your GitHub,</h1>
        <span class="hero-h1-outline">decoded.</span>
        <p class="hero-sub">Explore, analyze, and understand GitHub profiles in seconds.</p>
        <div class="hero-cta">
            <a href="/login" class="btn btn-primary">Start knowing the developer</a>
            <a href="#features" class="btn btn-ghost">see how it works</a>
        </div>
    </section>

    <!-- FEATURE STRIP -->
    <section class="feature-strip" id="features">
        <div class="feature-item">
            <div class="feature-num">01</div>
            <div class="feature-title">OAuth login</div>
            <p class="feature-desc">Sign in with Google. Secure, no passwords stored.</p>
        </div>
        <div class="feature-item">
            <div class="feature-num">02</div>
            <div class="feature-title">Live GitHub data</div>
            <p class="feature-desc">Stats, languages, and repos pulled live from the GitHub API.</p>
        </div>
        <div class="feature-item">
            <div class="feature-num">03</div>
            <div class="feature-title">Shareable card</div>
            <p class="feature-desc">One URL. Embed it anywhere. Export it as a card.</p>
        </div>
    </section>

    <!-- BOTTOM STRIP -->
    <div class="issue-strip">
        <span>DEVPRINT · NODE + EXPRESS + EJS + GITHUB API</span>
        <span>2025</span>
    </div>

</div>

</body>
</html>
